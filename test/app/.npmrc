# This nested test app deliberately does NOT install its own @sap/cds: it shares
# the plugin's copy (one dir up) so the linked plugin and the app use a single
# @sap/cds instance (otherwise the plugin's cds.on('loaded') hook registers on a
# different singleton and model augmentation silently no-ops). legacy-peer-deps
# stops npm from auto-installing @sap/cds as a peer dependency of @cap-js/*.
legacy-peer-deps=true
